    "axios": "^1.8.4",
    "bulma": "^0.9.4",
    "d3": "^7.9.0",
    "isbot": "^5",
    "lucide-react": "^0.488.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.0",
    "react-select": "^5.10.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@mdx-js/rollup": "^3.1.0",
    "@playwright/test": "^1.51.1",
    "@react-router/dev": "^7.5.0",
    "@types/node": "^22",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "isbot": "^5",
    "prettier": "^3.5.3",
    "react-router-devtools": "^1.1.10",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.1.0",
    "sass": "^1.86.3",
    "sass-loader": "16.0.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": false,
    "printWidth": 120
