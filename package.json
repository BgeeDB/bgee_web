{
  "name": "bgee",
  "version": "15.2.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && sh scripts/fix_symlinks.sh",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "stop": "/usr/bin/kill -TERM -- -$(ps aux | grep 'npm start' | grep -v grep | awk '{print $2}')",
    "restart": "npm run stop && npm run start",
    "typecheck": "react-router typegen && tsc",
    "fmt": "prettier --write . && eslint . --fix",
    "lint": "prettier --check . && eslint .",
    "test": "npx playwright test",
    "all": "npm run fmt && npm run typecheck && npm test",
    "postinstall": "npx playwright install --with-deps",
    "prepare": "husky",
    "upgrade": "npx npm-check-updates -u -x bulma && npm i",
    "archive": "node scripts/archiveCreation.js"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.6.3",
    "@react-router/node": "^7.6.3",
    "@react-router/serve": "^7.6.3",
    "@sib-swiss/sparql-editor": "^0.2.12",
    "axios": "^1.10.0",
    "bulma": "^0.9.4",
    "d3": "^7.9.0",
    "isbot": "^5",
    "lucide-react": "^0.507.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.3",
    "react-select": "^5.10.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@mdx-js/rollup": "^3.1.0",
    "@playwright/test": "^1.54.1",
    "@react-router/dev": "^7.6.3",
    "@types/node": "^22.16.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "react-router-devtools": "^5.0.6",
    "sass": "^1.89.2",
    "sass-loader": "16.0.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "prettier": {
    "trailingComma": "es5",
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": false,
    "printWidth": 120
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,mdx,html}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
